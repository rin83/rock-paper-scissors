import random

num = random.randint(1, 100)
print("я загадала число от 1 до 100")
c = 1

guess = int(input("Попробуй угадать:"))
while guess != num:
    if guess < num:
        print("Слишком маленьке число")
    elif num < guess < 100:
        print("Слишком большое число")
    else:
        print("Число не подходит")
    guess = int(input("Попробуй угадать:"))
    c += 1
print("Угадал!")
print("Число попыток:", c)